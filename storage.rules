rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Check if the user is the designated administrator
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == "AUdavid53@gmail.com" ||
        request.auth.token.email == "audavid53@gmail.com" ||
        request.auth.uid == "admin-uid-override"
      );
    }

    // Practice video submissions: owner can upload/read their own clips, Admin can read/delete any
    match /submissions/{userId}/{fileName} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.size < 50 * 1024 * 1024
                   && request.resource.contentType.matches('video/.*');
      allow delete: if isAdmin() || (request.auth != null && request.auth.uid == userId);
    }

    // Lesson visual assets: public read, Admin write only
    match /lessons/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
